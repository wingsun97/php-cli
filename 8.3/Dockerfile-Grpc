# =========================
# Grpc: ghcr.io/wingsun97/php-cli:8.3-grpc
# =========================

# =========================
# Stage 1: build grpc
# =========================
FROM ghcr.io/wingsun97/php-cli:8.3-core AS builder

# 基础镜像已包含 gcc/g++/make/autoconf/pkg-config/phpize
# grpc PECL 内置 boringssl/upb/abseil，仅需 zlib1g-dev（提供 zconf.h）
RUN apt-get update && apt-get install -y --no-install-recommends \
    zlib1g-dev \
 && rm -rf /var/lib/apt/lists/* \
 && pecl channel-update pecl.php.net \
 && printf "\n" | pecl install grpc-1.76.0 \
 && docker-php-ext-enable grpc \
 && strip --strip-all /usr/local/lib/php/extensions/no-debug-non-zts-20230831/grpc.so \
 && php -m | grep grpc

# =========================
# Stage 2: runtime
# =========================
FROM ghcr.io/wingsun97/php-cli:8.3-core

# grpc.so 仅链接 pthread/dl/rt/stdc++，基础镜像均已包含
COPY --from=builder /usr/local/lib/php/extensions/ /usr/local/lib/php/extensions/
COPY --from=builder /usr/local/etc/php/conf.d/ /usr/local/etc/php/conf.d/
